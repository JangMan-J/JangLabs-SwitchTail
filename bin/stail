#!/usr/bin/env bash
# stail — SwitchTail board umbrella CLI.
#
# Vocabulary (retro telephony / switchboard): a lab's window of agent panes is its BOARD;
# one agent pane is a LINE; a bundle of N parallel lines for one lab is a TRUNK; assembling
# a cart of lines into one board is PATCHing; closing a line so it resumes next launch is
# HOLDing it; the all-labs board is the EXCHANGE.
#
# Subcommands:
#   generate            (re)generate kitty session files + .desktop launchers, one per lab.
#   line <lab> [dir] [kind] [board]  per-pane launcher. kind = claude (default; hold-aware
#                       resume) | shell (a login $SHELL) | cmd:<argv> (an arbitrary command).
#                       board = the window the pane lives in (defaults to <lab>).
#   trunk  <lab> [N]    launch ONE board window for <lab> with N parallel claude lines.
#   patch  SPEC...      patch a cart of selections into ONE tabbed board.
#   active  [--json]    print the focused board's lab (the widget heading).
#   list    [--json]    list every lab and whether its board window is running.
#   switch  <lab>       raise the lab's board window if up, else launch its session.
#
# Window class stays switchtail-<lab> and the state dir stays switchtail — the verified
# contract the Plasma widget, the .desktop StartupWMClass, and the hold kitten all key on.
# active/list/switch introspect the live windows via kdotool by that class (the verified
# handle; kitty exposes no pid through KWin, so window-class search is the reliable
# signal, not pgrep).
#
# Tunables (env): SWITCHTAIL_DIR, SWITCHTAIL_INCLUDE_SHELL (1|0), SWITCHTAIL_LAYOUT (tall|fat|grid|...),
#   SWITCHTAIL_TRUNK_MAX (upper bound for `trunk`'s line count; default 12),
#   SWITCHTAIL_TAB_SIZE (panes per tab before `patch` overflows to a new tab; default 5).
set -uo pipefail

# ---------- shared config ----------
WORKSPACE="${SWITCHTAIL_DIR:-$HOME/JangLabs}"
OUTDIR="$HOME/.config/kitty/sessions/labs"
APPDIR="$HOME/.local/share/applications"
STATE="${XDG_STATE_HOME:-$HOME/.local/state}/switchtail"
EXT=".kitty-session"

usage() {
  cat >&2 <<'EOF'
stail — SwitchTail board CLI
usage:
  stail generate              regenerate kitty session + .desktop files (one per lab)
  stail line <lab> [dir] [kind] [board]   per-pane launcher (kind: claude|shell|cmd:<argv>)
  stail trunk   <lab> [N]     open one board window for <lab> with N claude lines (default 1)
  stail patch   SPEC...       patch a cart of selections into one tabbed board (see below)
  stail active  [--json]      print the focused board's lab (empty if not on one)
  stail list    [--json]      list every lab + whether its board window is running
  stail switch  <lab>         raise the lab's window if running, else launch its session

  patch SPEC: one or more of  lab=<name>[@<kind>][*N]  or  dir=<path>[@<kind>][*N]
    N    = panes, 1..5 each.   kind = claude (default) | shell | cmd:<argv>.
    e.g.  stail patch lab=claude*3 lab=agent dir=/srv/work/app*2
          stail patch lab=claude*2 lab=claude@shell dir=/srv/app@cmd:lazygit
    Panes pack 5-per-tab (overflow spills to new kitty tabs). Custom dirs get a
    slugged class switchtail-<slug> (collision-suffixed). The window class is the single
    selection's slug, or switchtail-multi for a mixed cart. shell/cmd panes never hold.
EOF
  exit "${1:-2}"
}

# ---------- shared: discover labs (top-level non-dot dirs except build/ that have a .git) ----------
# Lab names must fit [A-Za-z0-9._-]: the runtime contract encodes each name in a window
# class (switchtail-<lab>), a kdotool --class regex, JSON, and shell args, and a name with a
# space/quote/tab would corrupt all of those. Names outside the set are skipped with a
# warning (the os_window_class contract can't represent them anyway). Reserved names are
# skipped: `build/` (workspace invariant), `exchange` (the all-labs aggregate's runtime
# name -> class switchtail-exchange), and `switchtail-exchange` (it would collide with the
# aggregate's on-disk session basename switchtail-exchange.kitty-session, clobbering it).
_discover_labs() {  # echo VALID lab names, one per line, sorted; skip+warn on unusable names
  local d name labs=()
  shopt -s nullglob
  for d in "$WORKSPACE"/*/; do
    name="$(basename "$d")"
    case "$name" in build|exchange|switchtail-exchange) continue ;; esac
    [ -e "${d}.git" ] || continue
    if [[ ! "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then
      echo "stail: skipping lab '$name' — name has characters outside [A-Za-z0-9._-] the switchtail-<lab> window-class contract can't represent" >&2
      continue
    fi
    labs+=("$name")
  done
  [ ${#labs[@]} -gt 0 ] && printf '%s\n' "${labs[@]}" | sort
}

# ---------- shared: build an anchored, regex-safe kdotool --class pattern for a lab ----------
# kdotool --class is a REGEX. A literal '.'/'+' in a name would over-match or error, so we
# anchor (^…$) for exact-match semantics and escape every non-[A-Za-z0-9_-] char. Used by
# both _win_ids and cmd_switch (whose arg comes straight from the widget, not _discover_labs).
_class_re() {  # $1=lab -> echo ^switchtail-<escaped-lab>$
  local s="$1" out="" c i
  for (( i=0; i<${#s}; i++ )); do
    c="${s:i:1}"
    case "$c" in [A-Za-z0-9_-]) out+="$c" ;; *) out+="\\$c" ;; esac
  done
  printf '^switchtail-%s$' "$out"
}

# ---------- shared: human display name for a lab/slug (PascalCase) ----------
# The widget heading, the list, and every tab/pane title show this. Lab dirs are lowercase, so
# a plain Titlecase (first letter up) is the fallback; a few names carry an INTERNAL capital that
# can't be inferred from the lowercase dir (jangsjyro -> JangsJyro), so those are mapped explicitly.
# The single source of truth — change a display name here, not at each call site.
_display_name() {  # $1=lab/slug -> echo its PascalCase display name
  case "$1" in
    jangsjyro)  printf 'JangsJyro' ;;
    switchtail) printf 'SwitchTail' ;;   # SwitchTail develops itself as a lab (inner cap can't be inferred)
    exchange)   printf 'Exchange' ;;     # the all-labs aggregate board
    *)          printf '%s' "${1^}" ;;   # first char up, rest unchanged (preserves any inner caps)
  esac
}

# ---------- shared: window id(s) for a lab's board (exact class match) ----------
_win_ids() {  # $1=lab -> echo matching window id(s), one per line
  kdotool search --class "$(_class_re "$1")" 2>/dev/null
}

# ---------- shared: slug an arbitrary dir path to a [A-Za-z0-9._-] class token ----------
# A custom work dir has no lab name, so `patch` derives one from the basename: lowercase-ish,
# every char outside [A-Za-z0-9._-] collapsed to '-', leading/trailing '-' trimmed. Empty or
# all-punctuation basenames fall back to 'dir'. The caller (_patch_resolve) handles collisions
# with real labs / earlier specs by appending -2, -3, … so each slug is unique within the cart.
_slug_dir() {  # $1=path -> echo a class-safe slug
  local b s
  b="$(basename -- "$1")"
  s="$(printf '%s' "$b" | tr -c 'A-Za-z0-9._-' '-' )"
  s="${s##-}"; s="${s%%-}"          # trim a single leading/trailing dash
  s="${s//--/-}"                    # collapse doubled dashes from the tr
  [ -n "$s" ] || s="dir"
  printf '%s' "$s"
}

# Labs with a live board, from the stail-owned run markers — ONE state-dir scan, no
# kdotool, no KWin. A lab is UP iff ANY of its $STATE/run/<lab>/<pid> markers is live
# (_pane_alive: /proc/<pid>/stat exists AND its start time matches the recorded start= —
# the PID-reuse guard); a dead marker is rm -f'd in passing (lazy reap; rm -f is
# race-idempotent, so concurrent readers reaping the same file is harmless). Marker
# filenames are gated ^[0-9]+$ before ANY /proc or rm use — never trust a stray name.
# 'exchange' is emitted once iff any live marker anywhere carries board=exchange.
# Exchange-union truth (OQ-2, live accuracy): a lab counts as running-via-exchange ONLY
# while its exchange line is actually alive — a closed exchange pane no longer reports
# its lab running (the old _aggregate_labs session-FILE grep over-reported; retired).
_running_labs() {  # echo each running lab (+ 'exchange' if any live board=exchange marker)
  local d f lab pid start board saw_exchange=0
  shopt -s nullglob
  for d in "$STATE"/run/*/; do
    lab="$(basename "$d")"
    local up=0
    for f in "$d"*; do
      pid="$(basename "$f")"
      [[ "$pid" =~ ^[0-9]+$ ]] || continue          # never trust a stray filename
      start="$(grep -m1 '^start=' "$f" 2>/dev/null | cut -d= -f2)"
      if [ -n "$start" ] && _pane_alive "$pid" "$start"; then
        up=1
        board="$(grep -m1 '^board=' "$f" 2>/dev/null | cut -d= -f2)"
        [ "$board" = exchange ] && saw_exchange=1
      else
        rm -f "$f" 2>/dev/null                       # lazy reap; rm -f is race-idempotent
      fi
    done
    [ "$up" = 1 ] && printf '%s\n' "$lab"
  done
  [ "$saw_exchange" = 1 ] && printf 'exchange\n'
  return 0   # callers pipe this into grep -q under pipefail — never leak the && status
}

_need_kdotool() {  # $1=subcommand name, for the error message
  command -v kdotool >/dev/null 2>&1 || {
    echo "stail $1: kdotool not found — install it (paru -S kdotool); needed for window introspection" >&2
    exit 3
  }
}

# Validate a lab name taken from argv (board/switch). _discover_labs already gates generated
# names, but these two subcommands receive the lab straight from the caller (a Plasma widget),
# so they re-check before the name reaches a filesystem path ($STATE/$lab.hold, $OUTDIR/$lab)
# — a stray '../..' or space must not traverse out or corrupt the path.
_require_valid_lab() {  # $1=subcommand, $2=lab
  [[ "$2" =~ ^[A-Za-z0-9._-]+$ ]] || {
    echo "stail $1: invalid lab name '$2' (must match [A-Za-z0-9._-])" >&2; exit 2
  }
}

# ---------- shared: the labs the exchange (all-labs aggregate) board runs as lines ----------
# The aggregate is ONE window (class switchtail-exchange) running a claude pane per lab. These helpers
# read that pane set from its session file so 'list' can report those labs running and 'switch'
# can raise the aggregate instead of spawning a duplicate standalone window.
_aggregate_labs() {  # echo each lab the switchtail-exchange session runs, one per line
  [ -f "$OUTDIR/switchtail-exchange$EXT" ] || return 0
  grep -oE -- '--var lab=[A-Za-z0-9._-]+' "$OUTDIR/switchtail-exchange$EXT" 2>/dev/null | cut -d= -f2
}
_lab_in_aggregate() {  # $1=lab -> 0 if it is one of the aggregate's panes
  _aggregate_labs | grep -qxF -- "$1"
}

# ---------- shared: launch a GUI process fully detached from the caller ----------
# stail switch is meant to be invoked BY the Plasma widget — often a transient `bash=`
# applet action whose process subtree is torn down the instant it returns, reaping a
# plain `setsid … &` child before it reparents. A systemd --user transient SERVICE is
# spawned by the user manager, entirely outside the caller's tree (--scope/nohup/setsid
# do NOT escape — they stay descendants). The service does not inherit the caller env, so
# the GUI vars are passed explicitly. setsid is the non-systemd fallback.
# See memory method-detach-gui-from-transient-terminal-systemd-run.
_launch_detached() {  # "$@" = command to run detached
  if command -v systemd-run >/dev/null 2>&1; then
    local env_args=() v
    for v in WAYLAND_DISPLAY DISPLAY XDG_RUNTIME_DIR; do
      [ -n "${!v:-}" ] && env_args+=("--setenv=$v=${!v}")
    done
    systemd-run --user --quiet --collect "${env_args[@]}" -- "$@" 2>/dev/null && return 0
  fi
  setsid "$@" </dev/null >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

# ---------- shared: the KIND TABLE — single source of per-kind agent policy ----------
# Maps a pane kind to (fresh argv, continue argv, holdable, stylable). THE only place agent
# policy lives: the launch lines derive --var holdable/stylable from this table, and the
# hold/tail kittens gate on THOSE vars — never on a kind literal — so adding a new agent
# kind is one row here, not coordinated edits across the bash/python boundary.
#   fresh argv    — what a fresh pane execs; takes the pane's minted session id ($2) so a
#                   later hold can resume THIS pane specifically.
#   resume argv   — what a held pane execs to resume the exact session id ($2).
#   continue argv — the id-less fallback (legacy flag marker / unknown sid). MUST be
#                   cwd-scoped (resume the most recent session for the pane's directory):
#                   a globally-scoped continue would cross-wire labs. Verify this property
#                   before adding any row.
#   holdable      — the pane participates in the hold/resume marker protocol.
#   stylable      — the tail watcher types the boot styling payload into it.
# shell and cmd:<argv> kinds are handled structurally in cmd_line (not agent rows).
_kind_fresh_argv()    { case "$1" in claude) printf 'claude --session-id %s' "$2" ;; esac; }
_kind_resume_argv()   { case "$1" in claude) printf 'claude --resume %s' "$2" ;; esac; }
_kind_continue_argv() { case "$1" in claude) printf 'claude --continue' ;; esac; }
_kind_holdable()      { case "$1" in claude) return 0 ;; *) return 1 ;; esac; }
_kind_stylable()      { case "$1" in claude) return 0 ;; *) return 1 ;; esac; }

# ---------- shared: per-pane hold markers + session-id plumbing ----------
# A held pane is one EMPTY file $STATE/hold/<lab>/<session-id> — the filename IS the datum
# (schema: session id only), written by the hold kitten from the pane's sid user_var. N held
# panes for a lab = N files = N panes resume on the next trunk/board launch (the old single
# <lab>.hold flag collapsed N holds into one resume). mv is the claim primitive: when N
# panes boot concurrently, each rename succeeds for exactly one claimant — no double-consume
# race. The legacy <lab>.hold flag is still consumed (via the id-less continue argv) so a
# hold armed by an older kitten still resumes.
_SID_RE='^[0-9a-fA-F-]{8,64}$'
_new_sid() { uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid; }
_tag_sid() {  # $1=sid — stamp it on this pane's kitty window (OSC 1337 SetUserVar)
  [ -t 1 ] && printf '\033]1337;SetUserVar=sid=%s\007' "$(printf %s "$1" | base64 -w0)"
}
_hold_claim() {  # $1=lab -> echo one claimed session id, if any (atomic, first-wins)
  local d="$STATE/hold/$1" f sid
  [ -d "$d" ] || return 0
  for f in "$d"/*; do
    [ -e "$f" ] || continue
    sid="$(basename "$f")"
    [[ "$sid" =~ $_SID_RE ]] || continue   # never let a stray filename reach an exec argv
    if mv "$f" "$f.claimed.$$" 2>/dev/null; then
      rm -f "$f.claimed.$$"
      printf '%s\n' "$sid"
      return 0
    fi
  done
  return 0
}

# ---------- shared: per-pane RUN markers (running-state seam) ----------
# A live pane is one file $STATE/run/<lab>/<pid>, written by `stail line` BEFORE its exec —
# exec preserves the PID, so the filename IS the live agent process for the pane's whole
# life. Content lines: start=<jiffies> (the process start time, overall field 22 of
# /proc/<pid>/stat — the PID-reuse guard), board=<board> (the window the pane lives in),
# kind=<kind>, sid=<sid-or-empty> (informational; may be empty). Readers treat a marker as
# live iff /proc/<pid>/stat exists AND its start time matches the recorded one — a mismatch
# means the PID was reused, i.e. the pane is dead — else they rm -f it (lazy reap; rm -f is
# race-idempotent, so concurrent readers reaping the same marker is harmless). No locking:
# the writer names the file with its own PID, so every file has exactly ONE writer by
# construction, and writes go tmp + mv -f (the _hold_claim rename primitive) so a reader
# never sees a half-written marker. EVERY write step tolerates failure: set -uo pipefail is
# live, and a failed marker must degrade LISTING, never kill the pane — _run_mark returns 0
# unconditionally.
_run_mark() {  # $1=lab $2=board $3=kind $4=sid(may be empty) — NEVER fails the caller
  local d="$STATE/run/$1" stat rest start
  mkdir -p "$d" 2>/dev/null || return 0
  stat="$(cat /proc/$$/stat 2>/dev/null)" || return 0
  rest="${stat##*) }"                       # strip "pid (comm) " — comm may contain spaces
  start="$(awk '{print $20}' <<<"$rest")"   # overall field 22 = field 20 after the strip
  printf 'start=%s\nboard=%s\nkind=%s\nsid=%s\n' "$start" "$2" "$3" "${4:-}" \
    > "$d/$$.tmp" 2>/dev/null && mv -f "$d/$$.tmp" "$d/$$" 2>/dev/null
  return 0
}
_pane_alive() {  # $1=pid $2=recorded start -> 0 iff the same process is still alive
  local stat rest
  stat="$(cat "/proc/$1/stat" 2>/dev/null)" || return 1
  rest="${stat##*) }"
  [ "$(awk '{print $20}' <<<"$rest")" = "$2" ]
}

# ---------- shared: THE session emitter (single source of the kitty session grammar) ----------
# Every session this tool produces — per-lab file, aggregate, transient trunk, transient patch —
# flows through here, so the launch-line shape, the --var tags, and the packing rules live in
# exactly ONE place (this is the future multiplexer seam: a different backend means a different
# body for this function, not four scattered heredocs). Callers fill four parallel pane arrays
# via bash dynamic scope (the same pattern _patch_resolve already uses):
#   E_DIR[i]   pane working dir         E_LAB[i]   lab/slug (--var lab=, board's 1st arg)
#   E_KIND[i]  claude|shell|cmd:<argv>  E_TITLE[i] pane title
# Args: $1=window class  $2=layout  $3=tabmax:
#   0  = single tab: layout once up top, cd whenever the pane dir changes, focus the first pane.
#   >0 = pack N panes/tab: new_tab boundaries (named by the tab's first slug), per-tab cd+layout,
#        focus per tab master, focus_tab 0 trailer.
# Per pane: --var kind collapses cmd:<argv> to a space-free 'cmd'; the FULL kind is passed
# quoted as stail line's 3rd arg. --var holdable/stylable are derived from the kind table so
# the kittens gate on stail-computed policy, never on a kind literal.
_emit_session() {  # $1=class $2=layout $3=tabmax ; reads E_DIR/E_LAB/E_KIND/E_TITLE
  local cls="$1" layout="$2" tabmax="${3:-0}"
  local i in_tab=0 first_tab=1 prev_dir="" kind cvar flags board="${cls#switchtail-}"
  if [ "$tabmax" -eq 0 ]; then
    echo "layout $layout"
  fi
  echo "os_window_class $cls"
  for (( i=0; i<${#E_DIR[@]}; i++ )); do
    if [ "$tabmax" -gt 0 ] && [ "$in_tab" -eq 0 ]; then
      if [ "$first_tab" = 1 ]; then first_tab=0; else echo "new_tab $(_display_name "${E_LAB[$i]}")"; fi
      echo "cd ${E_DIR[$i]}"
      echo "layout $layout"
    elif [ "$tabmax" -eq 0 ] && [ "${E_DIR[$i]}" != "$prev_dir" ]; then
      echo "cd ${E_DIR[$i]}"; prev_dir="${E_DIR[$i]}"
    fi
    kind="${E_KIND[$i]}"
    case "$kind" in cmd:*) cvar="cmd" ;; *) cvar="$kind" ;; esac
    flags=""
    _kind_holdable "$cvar" && flags+=" --var holdable=1"
    _kind_stylable "$cvar" && flags+=" --var stylable=1"
    echo "launch --title \"${E_TITLE[$i]}\" --var lab=${E_LAB[$i]} --var board=$board --var kind=$cvar$flags stail line ${E_LAB[$i]} \"${E_DIR[$i]}\" \"$kind\" $board"
    if [ "$tabmax" -gt 0 ]; then
      [ "$in_tab" -eq 0 ] && echo "focus"
      in_tab=$((in_tab+1)); [ "$in_tab" -ge "$tabmax" ] && in_tab=0
    else
      [ "$i" -eq 0 ] && echo "focus"
    fi
  done
  [ "$tabmax" -gt 0 ] && echo "focus_tab 0"
  return 0
}

# ---------- generate helpers (read cmd_generate's locals via bash dynamic scope) ----------
_gen_is_submodule() {  # 0 if $1 is a path in .gitmodules
  git -C "$WORKSPACE" config --file "$WORKSPACE/.gitmodules" --get-regexp '^submodule\..*\.path$' 2>/dev/null \
    | awk '{print $2}' | grep -qx "$1"
}

_gen_emit_lab() {
  local lab="$1" path="$WORKSPACE/$1" file="$OUTDIR/$1$EXT" kind LAB
  kind="$(_gen_is_submodule "$lab" && echo 'submodule' || echo 'unregistered git repo')"
  LAB="$(_display_name "$lab")"
  local -a E_DIR=("$path") E_LAB=("$lab") E_KIND=(claude) E_TITLE=("$LAB")
  if [ "$INCLUDE_SHELL" = "1" ]; then
    E_DIR+=("$path"); E_LAB+=("$lab"); E_KIND+=(shell); E_TITLE+=("$LAB shell")
  fi
  {
    echo "$HDR"
    echo "# Lab: $lab ($kind)"
    _emit_session "switchtail-$lab" "$LAYOUT" 0
  } > "$file"
}

_gen_emit_all() {
  local file="$OUTDIR/switchtail-exchange$EXT" lab
  local -a E_DIR=() E_LAB=() E_KIND=() E_TITLE=()
  for lab in "${LABS[@]}"; do
    E_DIR+=("$WORKSPACE/$lab"); E_LAB+=("$lab"); E_KIND+=(claude); E_TITLE+=("$(_display_name "$lab")")
  done
  {
    echo "$HDR"
    echo "# Aggregate board: one claude per active lab, master+stack (first lab = master)."
    _emit_session "switchtail-exchange" "$LAYOUT" 0
  } > "$file"
}

_gen_emit_desktop() {  # $1=lab ("" => aggregate)
  local lab="$1" name file sess wmclass
  if [ -z "$lab" ]; then
    name="SwitchTail: exchange (all labs)"; file="$APPDIR/switchtail-exchange.desktop"
    sess="$OUTDIR/switchtail-exchange$EXT"; wmclass="switchtail-exchange"
  else
    name="SwitchTail: $lab (claude)"; file="$APPDIR/switchtail-$lab.desktop"
    sess="$OUTDIR/$lab$EXT"; wmclass="switchtail-$lab"
  fi
  cat > "$file" <<EOF
[Desktop Entry]
Type=Application
Name=$name
Comment=Open the ${lab:-all-labs} kitty board
Icon=utilities-terminal
Exec=kitty --session $sess
StartupWMClass=$wmclass
Categories=Development;Utility;
Terminal=false
EOF
}

# ---------- shared: emit a transient N-pane session for one lab (to stdout) ----------
# `trunk` opens ONE OS window (class switchtail-<lab>) holding N claude panes on the same repo
# — parallel agents on one lab, navigable by the numpad keys's positional nth_window. It is a
# transient, on-the-fly session piped into `kitty --session -` (no on-disk file; the per-lab
# .kitty-session files stay the canonical 1-master+shell layout and are untouched).
#
# Each pane carries the SAME --var lab/board=claude tags a generated master pane does, so the
# hold kitten (which gates close on those vars) holds any trunk pane exactly like a normal one.
# The first pane gets `focus` (master/hot-seat for the swap kitten). Panes share the lab's
# single .hold marker (one per lab by contract): holding any pane arms it, so the NEXT launch
# of that lab resumes — trunks are for fanning out fresh work, not per-pane resume.
_emit_trunk_session() {  # $1=lab, $2=count(validated int >=1) -> session text on stdout
  local lab="$1" n="$2" path="$WORKSPACE/$1" LAB i; LAB="$(_display_name "$1")"
  local -a E_DIR=() E_LAB=() E_KIND=() E_TITLE=()
  for (( i=1; i<=n; i++ )); do
    E_DIR+=("$path"); E_LAB+=("$lab"); E_KIND+=(claude); E_TITLE+=("$LAB $i")
  done
  echo "# TRANSIENT trunk session (stail trunk $lab $n) — not written to disk."
  _emit_session "switchtail-$lab" "${SWITCHTAIL_LAYOUT:-tall}" 0
}

# ---------- subcommand: generate ----------
cmd_generate() {
  local INCLUDE_SHELL LAYOUT HDR
  INCLUDE_SHELL="${SWITCHTAIL_INCLUDE_SHELL:-1}"   # 1 = add a side shell window per lab
  LAYOUT="${SWITCHTAIL_LAYOUT:-tall}"              # tall = master left + stack right (16:10-friendly)
  HDR="# AUTO-GENERATED by 'stail generate' — DO NOT EDIT (regenerated on submodule changes)."

  if [ ! -d "$WORKSPACE/.git" ] && [ ! -f "$WORKSPACE/.git" ]; then
    echo "stail generate: $WORKSPACE is not a git repo" >&2; return 1
  fi
  mkdir -p "$OUTDIR" "$APPDIR"
  shopt -s nullglob   # for the prune globs below (discovery sets its own in a subshell)

  local LABS=()
  mapfile -t LABS < <(_discover_labs)

  local lab
  for lab in "${LABS[@]}"; do _gen_emit_lab "$lab"; _gen_emit_desktop "$lab"; done
  _gen_emit_all
  _gen_emit_desktop ""

  # prune stale outputs for labs that no longer exist
  local -A keep=(); for lab in "${LABS[@]}"; do keep[$lab]=1; done
  local f b
  for f in "$OUTDIR"/*"$EXT"; do
    b="$(basename "$f" "$EXT")"; [ "$b" = "switchtail-exchange" ] && continue
    [ -n "${keep[$b]:-}" ] || rm -f "$f"
  done
  for f in "$APPDIR"/switchtail-*.desktop; do
    b="$(basename "$f" .desktop)"; b="${b#switchtail-}"; [ "$b" = "exchange" ] && continue
    [ -n "${keep[$b]:-}" ] || rm -f "$f"
  done
  command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database "$APPDIR" >/dev/null 2>&1 || true

  printf "stail generate: %d lab(s) -> %s [%s]\n" "${#LABS[@]}" "$OUTDIR" "${LABS[*]}"
}

# ---------- subcommand: line ----------
# Per-pane launcher run by every session line. The third arg is the pane KIND (default
# 'claude'), which decides what the pane execs:
#   <agent>      — a kind-table row (today: claude). Hold-aware resume per the table's
#                  holdable column; argv comes from the table, never hardcoded here.
#   shell        — an interactive login shell ($SHELL) in the lab dir. Never holds/resumes.
#   cmd:<argv>   — an arbitrary command, whitespace-split into argv (e.g. cmd:htop,
#                  cmd:git status, cmd:lazygit). Run via `exec` in the lab dir; never holds.
# The launch line passes --var kind=<kind> plus the table-derived --var holdable/stylable
# flags, so the pane's user_vars and the command it runs stay in lockstep — the hold kitten
# arms a marker only for holdable=1 panes, so a shell/cmd pane is never auto-closed.
#
# Resume model (holdable kinds only): a session resumes ONLY if it was deliberately "held"
# (Ctrl+Shift+R inside a board, handled by the hold kitten (hold.py), which writes the .hold
# marker). Any non-held exit (/exit, close_window, window X, crash, reboot) starts FRESH. The
# marker is one-shot. The previous transcript is never deleted — always reachable via
# `claude --resume`.
cmd_line() {
  local lab dir kind board marker fresh
  lab="${1:?usage: stail line <lab> [dir] [kind] [board]}"
  _require_valid_lab line "$lab"
  dir="${2:-$WORKSPACE/$lab}"
  kind="${3:-claude}"
  board="${4:-$lab}"   # pre-regen 3-arg session files default board to the lab
  # board reaches marker-file CONTENT only (never a path component), but _running_labs will
  # parse it back out — re-validate with _require_valid_lab's charset, degrading to the lab
  # rather than aborting (a malformed board must never kill the pane).
  [[ "$board" =~ ^[A-Za-z0-9._-]+$ ]] || board="$lab"
  mkdir -p "$STATE"
  cd "$dir" 2>/dev/null || { echo "stail line: dir '$dir' not found — aborting (refusing to root the pane in \$HOME)" >&2; exit 1; }
  # Run marker: written ONCE here, pre-dispatch, so claude, shell, AND cmd: panes all count
  # toward "board running" (parity with the old class-based counting — every pane is a
  # window pane). Written with sid= empty rather than per-branch after sid resolution: that
  # minimizes new code between the cd guard and the exec (a failure on this path must never
  # kill the pane — _run_mark cannot fail), and no Phase-1 reader consumes sid (the run-
  # marker contract above declares sid informational/optional).
  _run_mark "$lab" "$board" "$kind" ""
  case "$kind" in
    shell)
      exec "${SHELL:-/bin/sh}" -l
      ;;
    cmd:*)
      # cmd:<argv> — split the remainder on whitespace into an argv and exec it. This is a
      # convenience pane (a TUI/REPL/one-shot beside the agents), NOT a security boundary: the
      # spec comes from the user's own session/cart, so word-splitting (no quoting) is fine and
      # keeps `cmd:git status` ergonomic. An empty command is an error, not a silent shell.
      local rest=("${kind#cmd:}"); read -r -a rest <<< "${kind#cmd:}"
      [ "${#rest[@]}" -gt 0 ] || { echo "stail line: empty cmd: pane kind" >&2; exit 2; }
      exec "${rest[@]}"
      ;;
    *)
      # An agent kind — resolved through the kind table; unknown kinds are an error.
      if [ -z "$(_kind_fresh_argv "$kind" probe)" ]; then
        echo "stail line: unknown pane kind '$kind' (use claude | shell | cmd:<argv>)" >&2
        exit 2
      fi
      local sid
      if _kind_holdable "$kind"; then
        # 1) per-pane sid marker: resume that exact session, and re-tag the pane with the
        #    same sid so holding it again re-holds the same session.
        sid="$(_hold_claim "$lab")"
        if [ -n "$sid" ]; then
          _tag_sid "$sid"
          local -a cont; read -r -a cont <<< "$(_kind_resume_argv "$kind" "$sid")"
          exec "${cont[@]}"
        fi
        # 2) legacy single-flag marker: id-less continue (most recent session for this dir).
        marker="$STATE/$lab.hold"
        if [ -f "$marker" ]; then
          rm -f "$marker"
          local -a cont; read -r -a cont <<< "$(_kind_continue_argv "$kind")"
          exec "${cont[@]}"
        fi
      fi
      # fresh: mint a session id and stamp it on the pane so a later hold can target it.
      sid="$(_new_sid)"
      _tag_sid "$sid"
      local -a fr; read -r -a fr <<< "$(_kind_fresh_argv "$kind" "$sid")"
      exec "${fr[@]}"
      ;;
  esac
}

# ---------- subcommand: trunk ----------
# Open one board window for <lab> with N parallel claude panes (default 1). N is clamped to
# [1, SWITCHTAIL_TRUNK_MAX] (default max 12) so a fat-fingered `trunk claude 400` can't fork-bomb
# the box. The window is launched detached (same systemd-run path as `switch`) so invoking it
# from the transient Plasma-widget applet context survives the caller being reaped. The session
# is piped in via `kitty --session -` (STDIN) — no temp file to clean up or race.
cmd_trunk() {
  local lab="${1:?usage: stail trunk <lab> [N]}" n="${2:-1}" max
  _require_valid_lab trunk "$lab"
  max="${SWITCHTAIL_TRUNK_MAX:-12}"
  [[ "$max" =~ ^[1-9][0-9]*$ ]] || max=12
  if [[ ! "$n" =~ ^[0-9]+$ ]]; then
    echo "stail trunk: pane count '$n' is not a non-negative integer" >&2; exit 2
  fi
  if [ "$n" -lt 1 ]; then
    echo "stail trunk: pane count must be >= 1 (got $n)" >&2; exit 2
  fi
  if [ "$n" -gt "$max" ]; then
    echo "stail trunk: clamping pane count $n to SWITCHTAIL_TRUNK_MAX=$max" >&2; n="$max"
  fi
  if [ ! -d "$WORKSPACE/$lab" ]; then
    echo "stail trunk: lab dir '$WORKSPACE/$lab' not found — run 'stail generate'? (refusing to open a window of broken panes)" >&2
    exit 1
  fi
  # A standalone window for this lab already up? It shares the class, so this opens a SECOND
  # one (intended — a separate trunk) but `switch`/active would then raise/name arbitrarily
  # among them; surface that rather than silently doubling.
  if command -v kdotool >/dev/null 2>&1 && [ -n "$(_win_ids "$lab")" ]; then
    echo "stail trunk: a '$lab' board window is already up; opening a second (both share class switchtail-$lab)" >&2
  fi
  # The session is piped into `kitty --session -`, but the detach paths both sever the caller's
  # stdin: `systemd-run --user` drops stdin unless --pipe (which re-attaches synchronously,
  # defeating the detach) and the setsid fallback redirects </dev/null. So reconstruct the pipe
  # INSIDE the detached process: pass the session text as an argv, and have a small bash -c rebuild
  # it on the service's own stdin. No temp file to race/clean up.
  local sess; sess="$(_emit_trunk_session "$lab" "$n")"
  _launch_detached bash -c 'printf "%s\n" "$1" | kitty --session -' stail-trunk "$sess"
}

# ---------- subcommand: patch ----------
# Open ONE board window from a cart of selections, packing panes 5-per-tab (overflowing to
# new kitty tabs). The Plasma widget's primary launcher: the user checks several labs (each with
# a per-row session count) and/or an arbitrary work dir, then hits "Open board" -> this.
#
# SPEC tokens (one or more):  lab=<name>[@<kind>][*N]  |  dir=<path>[@<kind>][*N]
#   N    = pane count, 1..TAB_SIZE each (trailing *<digits>).
#   kind = the pane's command (trailing @<kind>): claude (default) | shell | cmd:<argv>.
#          e.g. lab=claude*3  dir=/srv/app  lab=agent@shell  dir=/srv/app@cmd:lazygit
# Resolution -> a flat ordered list of panes, each {dir, slug, kind, title}; slugs are de-duplicated
# (a custom dir whose basename collides with a real lab or an earlier spec gets -2, -3, …). The
# panes then pack SWITCHTAIL_TAB_SIZE (default 5) per tab. Window class = the single distinct slug,
# or switchtail-multi when the cart mixes slugs. claude panes carry --var kind=claude (hold + the
# numpad keys treat them as first-class); shell/cmd panes carry their own kind and never hold.
# Launched detached via the same stdin-rebuild path as trunk.

# A pane KIND is one of: claude | shell | cmd:<non-empty argv>. Used to peel a trailing @<kind>
# off a spec value WITHOUT mis-eating an '@' that is part of a path (e.g. dir=/home/u@host/proj):
# the suffix is only treated as a kind when it actually matches this set.
_is_pane_kind() {  # $1=candidate -> 0 if it is a valid pane kind
  case "$1" in claude|shell) return 0 ;; cmd:?*) return 0 ;; *) return 1 ;; esac
}

# Resolve SPECs -> four parallel arrays (P_DIR, P_SLUG, P_KIND, P_TITLE), one entry per pane, in
# order. Sets the bash-dynamic-scope arrays the caller declared. Returns nonzero on a bad spec/dir.
_patch_resolve() {  # "$@" = SPEC tokens; expects P_DIR/P_SLUG/P_KIND/P_TITLE/SLUGSEEN declared by caller
  local tok kind value count base dir slug uniq i tabmax pkind suffix
  tabmax="${SWITCHTAIL_TAB_SIZE:-5}"; [[ "$tabmax" =~ ^[1-9][0-9]*$ ]] || tabmax=5
  for tok in "$@"; do
    # split a trailing *<digits> count off the end
    count=1
    if [[ "$tok" =~ \*([0-9]+)$ ]]; then
      count="${BASH_REMATCH[1]}"; tok="${tok%\**}"
    fi
    kind="${tok%%=*}"; value="${tok#*=}"
    [ "$kind" = "$tok" ] && { echo "stail patch: malformed spec '$tok' (need lab=… or dir=…)" >&2; return 2; }
    if [[ ! "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ]; then
      echo "stail patch: spec '$tok' has bad count (need 1..$tabmax)" >&2; return 2
    fi
    [ "$count" -gt "$tabmax" ] && { echo "stail patch: clamping '$value' count $count to $tabmax" >&2; count="$tabmax"; }
    # peel a trailing @<kind> off the value — but only if the part after the LAST '@' is a real
    # pane kind, so a path/name containing '@' is left intact (dir=/home/u@host -> no kind eaten).
    pkind="claude"
    if [[ "$value" == *@* ]]; then
      suffix="${value##*@}"
      if _is_pane_kind "$suffix"; then pkind="$suffix"; value="${value%@*}"; fi
    fi
    case "$kind" in
      lab)
        _require_valid_lab patch "$value"
        dir="$WORKSPACE/$value"; slug="$value"
        [ -d "$dir" ] || { echo "stail patch: lab dir '$dir' not found — run 'stail generate'?" >&2; return 1; }
        ;;
      dir)
        # expand a leading ~ and resolve; must be an existing directory
        case "$value" in "~"/*) value="$HOME/${value#\~/}" ;; "~") value="$HOME" ;; esac
        [ -d "$value" ] || { echo "stail patch: work dir '$value' not found" >&2; return 1; }
        dir="$value"; slug="$(_slug_dir "$value")"
        ;;
      *) echo "stail patch: unknown spec kind '$kind' (use lab= or dir=)" >&2; return 2 ;;
    esac
    # de-duplicate the slug within this cart (so two windows/classes never collide in one patch)
    uniq="$slug"; i=2
    while [ -n "${SLUGSEEN[$uniq]:-}" ]; do uniq="${slug}-$i"; i=$((i+1)); done
    SLUGSEEN[$uniq]=1
    local disp; disp="$(_display_name "$uniq")"
    # title: claude panes are just "Name N"; a shell/cmd pane labels its kind so the tab is legible
    local ktag=""
    case "$pkind" in shell) ktag=" sh" ;; cmd:*) ktag=" ${pkind#cmd:}" ;; esac
    for (( i=1; i<=count; i++ )); do
      P_DIR+=("$dir"); P_SLUG+=("$uniq"); P_KIND+=("$pkind"); P_TITLE+=("$disp$ktag $i")
    done
  done
  [ "${#P_DIR[@]}" -gt 0 ]
}

# Emit the multi-tab session (to stdout) from the resolved pane arrays + a window class.
_emit_patch_session() {  # $1=class ; reads P_DIR/P_SLUG/P_KIND/P_TITLE by dynamic scope
  local cls="$1" layout tabmax
  layout="${SWITCHTAIL_LAYOUT:-tall}"
  tabmax="${SWITCHTAIL_TAB_SIZE:-5}"; [[ "$tabmax" =~ ^[1-9][0-9]*$ ]] || tabmax=5
  local -a E_DIR=("${P_DIR[@]}") E_LAB=("${P_SLUG[@]}") E_KIND=("${P_KIND[@]}") E_TITLE=("${P_TITLE[@]}")
  echo "# TRANSIENT patch session (stail patch) — not written to disk."
  _emit_session "$cls" "$layout" "$tabmax"
}

cmd_patch() {
  [ "$#" -gt 0 ] || { echo "stail patch: need at least one spec (lab=… or dir=…)" >&2; usage 2; }
  local -a P_DIR=() P_SLUG=() P_KIND=() P_TITLE=()
  local -A SLUGSEEN=()
  _patch_resolve "$@" || exit $?
  # window class: the single distinct slug, else a generic multi marker
  local cls distinct
  distinct="$(printf '%s\n' "${P_SLUG[@]}" | sort -u | wc -l)"
  if [ "$distinct" -eq 1 ]; then cls="switchtail-${P_SLUG[0]}"; else cls="switchtail-multi"; fi
  local sess; sess="$(_emit_patch_session "$cls")"
  _launch_detached bash -c 'printf "%s\n" "$1" | kitty --session -' stail-patch "$sess"
}

# ---------- subcommand: active ----------
# Print the lab of the currently focused board (the widget heading). Empty + exit 1 when
# not on a board. Source: $STATE/active — written by the kitty/state.py focus watcher
# (board name on focus gain, compare-and-clear on loss); no kdotool, no KWin. The named
# board is cross-checked against the live run markers: a stale file naming a dead board
# (kitty crash — no loss event ever fired) reports off-board, not the ghost. A missing
# file is the same off-board shape (the correct degraded mode before the watcher loads).
cmd_active() {
  local json=0 lab="" exchange=false f="$STATE/active"
  [ "${1:-}" = "--json" ] && json=1
  if [ -r "$f" ]; then
    lab="$(head -n1 "$f" 2>/dev/null)"
    [[ "$lab" =~ ^[A-Za-z0-9._-]+$ ]] || lab=""           # never let junk reach JSON
    if [ -n "$lab" ]; then                                # crash-staleness cross-check
      _running_labs | grep -qxF -- "$lab" || lab=""
    fi
    [ "$lab" = "exchange" ] && exchange=true
  fi
  if [ "$json" = 1 ]; then
    if [ -n "$lab" ]; then
      printf '{"lab":"%s","display":"%s","exchange":%s}\n' "$lab" "$(_display_name "$lab")" "$exchange"
    else
      printf '{"lab":null,"display":null,"exchange":false}\n'
    fi
  else
    [ -n "$lab" ] && printf '%s\n' "$lab"
  fi
  [ -n "$lab" ]   # exit 0 if on a board, 1 otherwise
}

# ---------- subcommand: list ----------
# Every lab + whether a board window for it is currently up.
cmd_list() {
  local json=0 lab first=1 running
  [ "${1:-}" = "--json" ] && json=1
  local labs=(); mapfile -t labs < <(_discover_labs)
  local running_set; running_set="$(_running_labs)"   # one state-dir scan, matched locally
  if [ "$json" = 1 ]; then
    printf '['
    for lab in "${labs[@]}"; do
      printf '%s\n' "$running_set" | grep -qxF -- "$lab" && running=true || running=false
      [ "$first" = 1 ] || printf ','
      printf '{"lab":"%s","display":"%s","running":%s}' "$lab" "$(_display_name "$lab")" "$running"
      first=0
    done
    printf ']\n'
  else
    for lab in "${labs[@]}"; do
      if printf '%s\n' "$running_set" | grep -qxF -- "$lab"; then printf '%-14s running\n' "$lab"
      else printf '%-14s -\n' "$lab"; fi
    done
  fi
}

# ---------- subcommand: switch ----------
# Raise the lab's board window if it's running; otherwise launch its session file.
cmd_switch() {
  _need_kdotool switch
  local lab="${1:?usage: stail switch <lab>}" sess ids exch_ids
  _require_valid_lab switch "$lab"
  if [ "$lab" = "exchange" ]; then sess="$OUTDIR/switchtail-exchange$EXT"; else sess="$OUTDIR/$lab$EXT"; fi
  ids="$(_win_ids "$lab")"
  if [ -n "$ids" ]; then
    # Reuse the ids we already have — re-searching here raced the launch path (a window
    # could vanish between the two searches) and picked arbitrarily among duplicates.
    [ "$(printf '%s\n' "$ids" | grep -c .)" -gt 1 ] && \
      echo "stail switch: multiple '$lab' board windows up; raising the first" >&2
    kdotool windowactivate "$(printf '%s\n' "$ids" | head -n1)" >/dev/null 2>&1
    return 0
  fi
  # No standalone window for this lab. If it is live as a line inside the exchange board,
  # raise THAT window rather than spawning a duplicate session — 'list' reports such a lab
  # running:true via the same union, so this keeps "running ⇒ switch raises" honest.
  if [ "$lab" != "exchange" ] && _lab_in_aggregate "$lab"; then
    exch_ids="$(_win_ids exchange)"
    if [ -n "$exch_ids" ]; then
      echo "stail switch: '$lab' runs as a line in the exchange board; raising it" >&2
      kdotool windowactivate "$(printf '%s\n' "$exch_ids" | head -n1)" >/dev/null 2>&1
      return 0
    fi
  fi
  if [ ! -f "$sess" ]; then
    echo "stail switch: no session for '$lab' ($sess) — run 'stail generate'?" >&2
    return 1
  fi
  _launch_detached kitty --session "$sess"
}

# ---------- dispatch ----------
sub="${1:-}"; [ $# -gt 0 ] && shift
case "$sub" in
  generate) cmd_generate "$@" ;;
  line)     cmd_line "$@" ;;
  trunk)    cmd_trunk "$@" ;;
  patch)    cmd_patch "$@" ;;
  active)   cmd_active "$@" ;;
  list)     cmd_list "$@" ;;
  switch)   cmd_switch "$@" ;;
  ""|-h|--help|help) usage 0 ;;
  *) echo "stail: unknown subcommand '$sub'" >&2; usage 2 ;;
esac
